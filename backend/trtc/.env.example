# Tencent Cloud credentials (from https://console.cloud.tencent.com/cam/capi)
TENCENT_SECRET_ID=your_secret_id_here
TENCENT_SECRET_KEY=your_secret_key_here
TENCENT_REGION=ap-singapore

# TRTC App credentials (from https://console.cloud.tencent.com/trtc)
TRTC_SDK_APP_ID=20041870
TRTC_USER_ID=your_user_id
TRTC_USER_SIG=your_user_sig
TRTC_ROBOT_USER_ID=robot_id
TRTC_ROBOT_USER_SIG=your_robot_sig

# STT — Deepgram (https://deepgram.com)
DEEPGRAM_API_KEY=your_deepgram_key

# LLM — OpenAI or compatible endpoint
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=your_openai_key
LLM_MODEL=gpt-4o

# TTS — ElevenLabs (https://elevenlabs.io)
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=your_voice_id
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Optional welcome message
TRTC_WELCOME_MESSAGE=Hi! I'm your SCU Course Optimizer advisor! Ask me anything about professors. Unless you're Damian, don't ask me anything Damian...

PORT=3000
